# ─────────────────────────────────────────
# TradeMinds — Environment Configuration
# Copy to .env and fill in all values
# ─────────────────────────────────────────

# ─── App ───
APP_NAME=TradeMinds
DEBUG=false
ALLOWED_ORIGINS=["https://yourdomain.com","http://localhost:3000"]

# ─── Security (generate with: openssl rand -hex 64) ───
SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_64
BROKER_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32

# ─── Database ───
DATABASE_URL=postgresql+asyncpg://trademinds:YOUR_DB_PASSWORD@localhost:5432/trademinds

# ─── Redis ───
REDIS_URL=redis://:YOUR_REDIS_PASSWORD@localhost:6379/0

# ─── Anthropic Claude API ───
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── MyFXBook Economic Calendar ───

# ─── Notifications ───
# Telegram: create bot via @BotFather, get chat ID via @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Gmail: use App Password, not your regular password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_gmail_app_password
NOTIFICATION_EMAIL=notify@youremail.com

# ─── Bot Defaults ───
BASE_CURRENCY=USD
BOT_MAX_POSITIONS=25
BOT_MAX_DAILY_LOSS_PCT=5.0
BOT_MAX_RISK_PER_TRADE_PCT=1.0
BOT_NEWS_PAUSE_MINUTES=30
